{
  "name": "token-health-windows",
  "version": "0.1.0",
  "description": "Token Health Windows Electron MVP",
  "private": true,
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:installer": "npm run build && electron-builder --win nsis --x64",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "smoke:build": "node tests/build-smoke.mjs",
    "smoke:electron": "node tests/electron-smoke.mjs"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@vitejs/plugin-react": "4.4.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.15.32",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitest/coverage-v8": "3.2.4",
    "electron": "37.1.0",
    "electron-builder": "26.0.12",
    "electron-vite": "4.0.0",
    "eslint": "9.30.1",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.2.0",
    "jsdom": "26.1.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.35.0",
    "vite": "6.4.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "build": {
    "appId": "com.imblues.tokenhealth.windows",
    "productName": "Token Health",
    "artifactName": "TokenHealth-Windows-${version}-${arch}-Setup.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "build/icon.png",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.png",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "unicode": true,
      "warningsAsErrors": true
    }
  }
}
